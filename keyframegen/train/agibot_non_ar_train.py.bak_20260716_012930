def gradient_group_stats(
    groups: Dict[str, List[Tuple[str, nn.Parameter]]],
    distributed: bool,
    aggregate_across_ranks: bool,
    device,
) -> Dict[str, Dict[str, float]]:
    stats: Dict[str, Dict[str, float]] = {}
    for group_name, items in groups.items():
        if not items:
            continue
        totals = torch.zeros(6, device=device, dtype=torch.float64)
        for _, parameter in items:
            totals[4] += 1
            grad = parameter.grad
            if grad is None:
                totals[3] += 1
                continue
            grad_float = grad.detach().float()
            finite = torch.isfinite(grad_float)
            finite_grad = torch.where(finite, grad_float, torch.zeros_like(grad_float))
            totals[0] += finite_grad.pow(2).sum().double()
            totals[1] += grad_float.numel()
            totals[2] += (grad_float == 0).sum().double()
            totals[5] += (~finite).sum().double()
        if distributed and aggregate_across_ranks:
            torch.distributed.all_reduce(totals, op=torch.distributed.ReduceOp.SUM)
        grad_elements = totals[1].clamp_min(1.0)
        param_count = totals[4].clamp_min(1.0)
        stats[group_name] = {
            "norm": float(torch.sqrt(totals[0]).item()),
            "rms": float(torch.sqrt(totals[0] / grad_elements).item()),
            "grad_elements": float(totals[1].item()),
            "none_fraction": float((totals[3] / param_count).item()),
            "zero_fraction": float((totals[2] / grad_elements).item()),
            "nonfinite_count": float(totals[5].item()),
            "sum_sq": float(totals[0].item()),
        }
    return stats


def log_gradient_diagnostics(
    writer,
    rank: int,
    global_step: int,
    group_stats: Dict[str, Dict[str, float]],
    log_global: bool,
    log_groups: bool,
    log_nonfinite: bool,
) -> None:
    if writer is None or rank != 0:
        return
    if log_global:
        global_sum_sq = sum(item["sum_sq"] for item in group_stats.values())
        writer.add_scalar(
            "train/grad_norm/global",
            math.sqrt(max(0.0, global_sum_sq)),
            global_step,
        )
    for group_name, item in group_stats.items():
        if log_groups:
            writer.add_scalar(
                f"train/grad_norm/{group_name}", item["norm"], global_step
            )
            writer.add_scalar(
                f"train/grad_rms/{group_name}", item["rms"], global_step
            )
            writer.add_scalar(
                f"train/grad_none_fraction/{group_name}",
                item["none_fraction"],
                global_step,
            )
            writer.add_scalar(
                f"train/grad_zero_fraction/{group_name}",
                item["zero_fraction"],
                global_step,
            )
        if log_nonfinite:
            writer.add_scalar(
                f"train/grad_nonfinite_count/{group_name}",
                item["nonfinite_count"],
                global_step,
            )


@torch.no_grad()
def run_validation(
    pipe,
    engine,
    val_samples: List[str],
    val_task_names: List[str],
    cfg: Dict[str, Any],
    flow_cfg: FlowMatchingConfig,
    distributed: bool,
    rank: int,
    world_size: int,
    global_step: int,
    writer,
) -> None:
    if not val_samples:
        return

    train_cfg = cfg["train"]
    data_cfg = cfg["data"]
    val_cfg = train_cfg.get("validation", {})
    mode = train_cfg["conditioning_mode"]
    expected_slots = int(data_cfg["expected_num_slots"])
    seed = int(val_cfg.get("seed", 12345))
    num_bins = int(val_cfg.get("num_timestep_bins", 4))
    task_to_index = {task: index for index, task in enumerate(val_task_names)}
    device = pipe.device

    totals = torch.zeros(5, device=device, dtype=torch.float64)
    slot_totals = torch.zeros(
        expected_slots, 2, device=device, dtype=torch.float64
    )
    bin_totals = torch.zeros(
        num_bins, 2, device=device, dtype=torch.float64
    )
    task_totals = torch.zeros(
        len(val_task_names), 2, device=device, dtype=torch.float64
    )

    engine.eval()

    rank_items = [
        (sample_index, sample_dir)
        for sample_index, sample_dir in enumerate(val_samples)
        if sample_index % world_size == rank
    ]

    for sample_index, sample_dir in rank_items:
        item = load_cached_item(
            sample_dir=sample_dir,
            data_cfg=data_cfg,
            conditioning_mode=mode,
            device=device,
            expected_slots=expected_slots,
        )
        target = item["target_latents"]
        noise, timestep_index, timestep = fixed_validation_noise_and_timestep(
            target.shape,
            sample_index=sample_index,
            seed=seed,
            flow_cfg=flow_cfg,
            device=device,
            dtype=target.dtype,
            scheduler=pipe.scheduler,
        )
        fm_batch = build_flow_matching_batch(
            pipe=pipe,
            target_latents=target,
            first_frame_latents=item["first_frame_latents"],
            fuse_vae_embedding_in_latents=bool(
                item["fuse_vae_embedding_in_latents"]
            ),
            flow_cfg=flow_cfg,
            deterministic_noise=noise,
            deterministic_timestep_index=timestep_index,
            deterministic_timestep=timestep,
        )

        model_kwargs = dict(
            latents=fm_batch.noisy_latents,
            timestep=fm_batch.timestep,
            clip_feature=item["clip_feature"],
            y=item["y"],
            fuse_vae_embedding_in_latents=item[
                "fuse_vae_embedding_in_latents"
            ],
            use_gradient_checkpointing=False,
            use_gradient_checkpointing_offload=False,
        )
        model_kwargs.update(item["conditions"])

        with torch.autocast(
            device_type="cuda",
            dtype=torch.bfloat16,
            enabled=torch.cuda.is_available(),
        ):
            pred = engine(**model_kwargs)
            error = (pred.float() - fm_batch.training_target.float()).pow(2)
            mask = fm_batch.loss_mask.float()

        numerator, denominator = loss_parts(error, mask)
        weighted_numerator = numerator * fm_batch.training_weight.to(numerator)
        totals[0] += numerator.double()
        totals[1] += denominator.double()
        totals[2] += weighted_numerator.double()
        totals[3] += denominator.double()
        totals[4] += fm_batch.training_weight.double()

        for slot in range(1, expected_slots):
            slot_num, slot_den = loss_parts(error[:, :, slot], mask[:, :, slot])
            slot_totals[slot, 0] += slot_num.double()
            slot_totals[slot, 1] += slot_den.double()

        bin_index = sigma_bin(fm_batch.sigma, num_bins)
        bin_totals[bin_index, 0] += numerator.double()
        bin_totals[bin_index, 1] += denominator.double()

        task_name = item["sample_id"].split("/", 1)[0]
        task_index = task_to_index.get(task_name)
        if task_index is not None:
            task_totals[task_index, 0] += numerator.double()
            task_totals[task_index, 1] += denominator.double()

        del (
            item,
            target,
            noise,
            timestep,
            fm_batch,
            pred,
            error,
            mask,
        )

    totals = all_reduce_sum(totals, distributed)
    slot_totals = all_reduce_sum(slot_totals, distributed)
    bin_totals = all_reduce_sum(bin_totals, distributed)
    task_totals = all_reduce_sum(task_totals, distributed)

    if rank == 0:
        val_loss_unweighted = totals[0] / totals[1].clamp_min(1.0)
        val_loss_weighted = totals[2] / totals[3].clamp_min(1.0)
        weight_mean = totals[4] / max(1, len(val_samples))
        writer.add_scalar(
            "val/loss_unweighted", float(val_loss_unweighted.item()), global_step
        )
        writer.add_scalar(
            "val/loss_weighted", float(val_loss_weighted.item()), global_step
        )
        writer.add_scalar("val/loss", float(val_loss_weighted.item()), global_step)
        writer.add_scalar(
            "val/timestep_weight_mean", float(weight_mean.item()), global_step
        )
        for slot in range(1, expected_slots):
            slot_loss = slot_totals[slot, 0] / slot_totals[slot, 1].clamp_min(1.0)
            writer.add_scalar(
                f"val/loss_by_slot/slot_{slot}",
                float(slot_loss.item()),
                global_step,
            )
        for bin_index in range(num_bins):
            bin_loss = (
                bin_totals[bin_index, 0]
                / bin_totals[bin_index, 1].clamp_min(1.0)
            )
            writer.add_scalar(
                f"val/loss_by_sigma_bin/bin_{bin_index}",
                float(bin_loss.item()),
                global_step,
            )
        for task_index, task_name in enumerate(val_task_names):
            task_loss = (
                task_totals[task_index, 0]
                / task_totals[task_index, 1].clamp_min(1.0)
            )
            writer.add_scalar(
                f"val/loss_by_task/{task_name}",
                float(task_loss.item()),
                global_step,
            )
        rank0_print(
            rank,
            f"[val] step={global_step:06d} samples={len(val_samples)} "
            f"loss_unweighted={float(val_loss_unweighted.item()):.6f} "
            f"loss_weighted={float(val_loss_weighted.item()):.6f}",
        )

    engine.train()


def validate_config(cfg: Dict[str, Any], world_size: int) -> None:
    required = ["model", "data", "train", "deepspeed"]
    for key in required:
        if key not in cfg:
            raise KeyError(f"Missing config section: {key}")

    mode = cfg["train"]["conditioning_mode"]
    if mode not in {"local_only", "dual_context"}:
        raise ValueError(f"Invalid conditioning_mode: {mode}")

    ds = cfg["deepspeed"]
    micro = int(ds["train_micro_batch_size_per_gpu"])
    accum = int(ds["gradient_accumulation_steps"])
    expected = micro * accum * world_size
    if int(ds["train_batch_size"]) != expected:
        raise ValueError(
            f"deepspeed.train_batch_size={ds['train_batch_size']} but "
            f"world_size*micro*accum={expected}"
        )
    if micro != 1:
        raise ValueError(
            "This cache-streaming trainer currently requires "
            "train_micro_batch_size_per_gpu=1."
        )


def assert_resume_flow_matching_compatible(
    checkpoint_flow_matching: Optional[Dict[str, Any]],
    current_flow_cfg: FlowMatchingConfig,
) -> None:
    if checkpoint_flow_matching is None:
        raise ValueError(
            "Full resume checkpoint has no flow_matching metadata; refusing "
            "to resume without train.flow_matching.allow_resume_mismatch=true"
        )
    current = current_flow_cfg.to_dict()
    keys = ["mode"]
    if current_flow_cfg.mode == "diffsynth_wan":
        keys.extend(["num_train_timesteps", "sigma_shift"])
    for key in keys:
        if checkpoint_flow_matching.get(key) != current.get(key):
            raise ValueError(
                f"Flow matching resume mismatch for {key}: checkpoint="
                f"{checkpoint_flow_matching.get(key)!r}, current={current.get(key)!r}. "
                "Set train.flow_matching.allow_resume_mismatch=true only for "
                "an intentional ablation."
            )


def train(cfg: Dict[str, Any]) -> None:
    distributed, rank, world_size, local_rank = init_distributed()
    validate_config(cfg, world_size)

    train_cfg = cfg["train"]
    data_cfg = cfg["data"]
    mode = train_cfg["conditioning_mode"]
    flow_cfg = parse_flow_matching_config(train_cfg)
    lr_cfg = parse_lr_scheduler_config(train_cfg)
    diagnostics_cfg = parse_diagnostics_config(train_cfg)
    cfg["train"]["flow_matching"] = flow_cfg.to_dict()
    cfg["train"]["lr_scheduler"] = lr_cfg.to_dict()
    cfg["train"]["diagnostics"] = diagnostics_cfg.to_dict()
    seed_everything(int(train_cfg["seed"]), rank)

    out_dir = Path(train_cfg["out_dir"])
    ckpt_root = out_dir / "checkpoints"
    ds_ckpt_dir = ckpt_root / "deepspeed"
    tb_dir = out_dir / "tb"

    if rank == 0:
        ensure_dir(str(out_dir))
        ensure_dir(str(ckpt_root))
        ensure_dir(str(ds_ckpt_dir))
        ensure_dir(str(tb_dir))
        with open(out_dir / "config.json", "w", encoding="utf-8") as f:
            json.dump(cfg, f, ensure_ascii=False, indent=2)
    barrier(distributed, local_rank)

    train_samples = [
        resolve_manifest_item(item, data_root=data_cfg.get("data_root"))
        for item in read_manifest(data_cfg["train_manifest"])
    ]
    if not train_samples:
        raise ValueError("Empty training manifest.")
    sample_ids = [read_sample_id(sample_dir) for sample_dir in train_samples]
    duplicate_sample_ids = sorted(
        sample_id
        for sample_id in set(sample_ids)
        if sample_ids.count(sample_id) > 1
    )
    if duplicate_sample_ids:
        raise ValueError(
            "Duplicate sample IDs in training manifest: "
            + ", ".join(duplicate_sample_ids[:20])
        )

    rank0_print(
        rank,
        f"[data] samples={len(train_samples)} mode={mode} "
        f"expected_slots={data_cfg['expected_num_slots']}",
    )
    rank0_print(rank, f"[flow_matching] {json.dumps(flow_cfg.to_dict(), sort_keys=True)}")
    rank0_print(rank, f"[lr_scheduler] {json.dumps(lr_cfg.to_dict(), sort_keys=True)}")
    rank0_print(
        rank,
        f"[diagnostics] {json.dumps(diagnostics_cfg.to_dict(), sort_keys=True)}",
    )

    validation_cfg = train_cfg.get("validation", {})
    val_samples = []
    val_task_names = []
    if bool(validation_cfg.get("enabled", False)):
        val_manifest = validation_cfg.get("manifest") or data_cfg.get("val_manifest")
        if not val_manifest:
            raise ValueError("train.validation.enabled=true but no val manifest is set")
        val_samples = [
            resolve_manifest_item(item, data_root=data_cfg.get("data_root"))
            for item in read_manifest(val_manifest)
        ]
        if not val_samples:
            raise ValueError(f"Empty validation manifest: {val_manifest}")
        val_task_names = sorted(
            {read_sample_id(sample_dir).split("/", 1)[0] for sample_dir in val_samples}
        )
        rank0_print(
            rank,
            f"[val] enabled samples={len(val_samples)} every_steps="
            f"{int(validation_cfg.get('every_steps', 150))} "
            f"seed={int(validation_cfg.get('seed', 12345))} "
            f"tasks={','.join(val_task_names)}",
        )

    pipe = build_pipe(cfg, mode, local_rank)
    initialize_flow_matching_scheduler(pipe, flow_cfg)
    pipe.load_models_to_device(["dit"])
    pipe.dit.train()

    param_groups, named_trainable = configure_trainable(pipe.dit, train_cfg, rank)
    print_absent_parameter_groups(param_groups, rank)
    expected_trainable_ids = trainable_parameter_ids(pipe.dit)
    optimizer, parameters = build_optimizer(
        param_groups, train_cfg, named_trainable
    )
    lr_scheduler_factory = lambda basic_optimizer: build_lr_scheduler(
        basic_optimizer, lr_cfg
    )
    training_module = KeyframeWanTrainingModule(pipe)

    engine, optimizer, _, _ = deepspeed.initialize(
        model=training_module,
        optimizer=optimizer,
        model_parameters=parameters,
        lr_scheduler=lr_scheduler_factory,
        config=cfg["deepspeed"],
    )
    assert_training_module_ownership(
        training_module=training_module,
        engine=engine,
        expected_trainable_ids=expected_trainable_ids,
        rank=rank,
        local_rank=local_rank,
    )
    engine.module.dit.train()

    resume_cfg = train_cfg["resume"]
    global_step = 0
    micro_step = 0

    if resume_cfg["mode"] == "full":
        load_path, client_state = engine.load_checkpoint(
            resume_cfg["path"],
            tag=resume_cfg.get("tag"),
            load_module_strict=False,
            load_optimizer_states=True,
            load_lr_scheduler_states=True,
        )
        if load_path is None:
            raise RuntimeError(
                f"Failed to load DeepSpeed checkpoint from {resume_cfg['path']}"
            )
        client_state = client_state or {}
        if client_state.get("training_module") != "KeyframeWanTrainingModule/v1":
            raise RuntimeError(
                "This full DeepSpeed checkpoint was not saved with the current "
                "KeyframeWanTrainingModule wrapper. Use a lightweight trainable "
                "checkpoint for pre-wrapper runs, or start a new full checkpoint."
            )
        if not flow_cfg.allow_resume_mismatch:
            assert_resume_flow_matching_compatible(
                client_state.get("flow_matching"), flow_cfg
            )
        elif rank == 0:
            rank0_print(
                rank,
                "[resume full] WARNING: flow matching mismatch checks are disabled",
            )
        global_step = int(client_state.get("global_step", 0))
        micro_step = int(client_state.get("micro_step", 0))
        restore_rng_state(client_state.get("rng_state"))
        rank0_print(
            rank,
            f"[resume full] path={load_path} global_step={global_step} "
            f"micro_step={micro_step}",
        )
    elif resume_cfg["mode"] == "weights":
        global_step = load_trainable_weights(
            engine.module.dit, resume_cfg["path"], rank
        )
        rank0_print(
            rank,
            "[resume weights] WARNING: optimizer/scheduler state is not loaded; "
            "the current flow_matching configuration starts a new ablation.",
        )
        if not bool(resume_cfg.get("keep_step", False)):
            global_step = 0
        micro_step = global_step * int(
            cfg["deepspeed"]["gradient_accumulation_steps"]
        )
    elif resume_cfg["mode"] != "none":
        raise ValueError(f"Unknown resume mode: {resume_cfg['mode']}")

    writer = SummaryWriter(str(tb_dir)) if rank == 0 else None

    max_steps = int(train_cfg["max_steps"])
    accum_steps = int(cfg["deepspeed"]["gradient_accumulation_steps"])
    shuffle = bool(data_cfg["shuffle"])
    shuffle_seed = int(data_cfg["shuffle_seed"])
    log_every = int(train_cfg["log_every"])
    save_every = int(train_cfg["save_every"])
    empty_cache_every = int(train_cfg["empty_cache_every"])
    expected_slots = int(data_cfg["expected_num_slots"])

    rank0_print(
        rank,
        f"[train] global_step={global_step} -> {max_steps} "
        f"world_size={world_size} accum={accum_steps}",
    )

    last_loss_value = float("nan")
    printed_first_batch = False
    log_window_loss_sum = torch.zeros((), device=pipe.device, dtype=torch.float32)
    log_window_unweighted_loss_sum = torch.zeros(
        (), device=pipe.device, dtype=torch.float32
    )
    log_window_weighted_loss_sum = torch.zeros(
        (), device=pipe.device, dtype=torch.float32
    )
    log_window_timestep_sum = torch.zeros((), device=pipe.device, dtype=torch.float32)
    log_window_timestep_index_sum = torch.zeros(
        (), device=pipe.device, dtype=torch.float32
    )
    log_window_sigma_sum = torch.zeros((), device=pipe.device, dtype=torch.float32)
    log_window_weight_sum = torch.zeros((), device=pipe.device, dtype=torch.float32)
    log_window_slot_sums = {
        slot: torch.zeros((), device=pipe.device, dtype=torch.float32)
        for slot in range(1, expected_slots)
    }
    log_window_micro_batches = 0

    while global_step < max_steps:
        # Deterministic distributed stream. Restoring micro_step exactly restores
        # epoch, rank-local sample position, and next sample.
        global_item_index = micro_step * world_size + rank
        epoch = global_item_index // len(train_samples)
        position = global_item_index % len(train_samples)
        order = make_epoch_order(
            len(train_samples), epoch, shuffle_seed, shuffle
        )
        sample_dir = train_samples[order[position]]

        item = load_cached_item(
            sample_dir=sample_dir,
            data_cfg=data_cfg,
            conditioning_mode=mode,
            device=pipe.device,
            expected_slots=expected_slots,
        )
        if not printed_first_batch:
            print_first_batch_summary(rank, item)
            printed_first_batch = True

        engine.train()

        target = item["target_latents"]
        fm_batch = build_flow_matching_batch(
            pipe=pipe,
            target_latents=target,
            first_frame_latents=item["first_frame_latents"],
            fuse_vae_embedding_in_latents=bool(
                item["fuse_vae_embedding_in_latents"]
            ),
            flow_cfg=flow_cfg,
        )

        model_kwargs = dict(
            latents=fm_batch.noisy_latents,
            timestep=fm_batch.timestep,
            clip_feature=item["clip_feature"],
            y=item["y"],
            fuse_vae_embedding_in_latents=item[
                "fuse_vae_embedding_in_latents"
            ],
            use_gradient_checkpointing=bool(
                train_cfg["use_gradient_checkpointing"]
            ),
            use_gradient_checkpointing_offload=bool(
                train_cfg["use_gradient_checkpointing_offload"]
            ),
        )
        model_kwargs.update(item["conditions"])

        with torch.autocast(
            device_type="cuda",
            dtype=torch.bfloat16,
            enabled=torch.cuda.is_available(),
        ):
            pred = engine(**model_kwargs)
            error = (pred.float() - fm_batch.training_target.float()).pow(2)
            mask = fm_batch.loss_mask.float()
            unweighted_loss = masked_mse_loss(error, mask)
            weighted_loss = unweighted_loss * fm_batch.training_weight.to(
                unweighted_loss
            )
            loss = weighted_loss if flow_cfg.use_training_weight else unweighted_loss
            per_slot_losses = slot_mse_losses(error.detach(), mask.detach())

        timestep_index_tensor = torch.tensor(
            -1.0 if fm_batch.timestep_index is None else float(fm_batch.timestep_index),
            device=pipe.device,
            dtype=torch.float32,
        )
        log_window_loss_sum += loss.detach().float()
        log_window_unweighted_loss_sum += unweighted_loss.detach().float()
        log_window_weighted_loss_sum += weighted_loss.detach().float()
        log_window_timestep_sum += fm_batch.timestep.detach().float().mean()
        log_window_timestep_index_sum += timestep_index_tensor
        log_window_sigma_sum += fm_batch.sigma.detach().float().reshape(())
        log_window_weight_sum += fm_batch.training_weight.detach().float().reshape(())
        for slot, slot_loss in per_slot_losses.items():
            log_window_slot_sums[slot] += slot_loss.detach().float()
        log_window_micro_batches += 1

        engine.backward(loss)
        accumulation_boundary = engine.is_gradient_accumulation_boundary()
        diagnostics_step = global_step + 1
        if accumulation_boundary and (
            should_log_every(diagnostics_step, diagnostics_cfg.grad_norm_every)
            or should_log_every(diagnostics_step, diagnostics_cfg.grad_group_every)
            or should_log_every(diagnostics_step, diagnostics_cfg.check_nonfinite_every)
        ):
            group_stats = gradient_group_stats(
                groups=param_groups,
                distributed=distributed,
                aggregate_across_ranks=gradients_are_partitioned(engine),
                device=pipe.device,
            )
            log_gradient_diagnostics(
                writer=writer,
                rank=rank,
                global_step=diagnostics_step,
                group_stats=group_stats,
                log_global=should_log_every(
                    diagnostics_step, diagnostics_cfg.grad_norm_every
                ),
                log_groups=should_log_every(
                    diagnostics_step, diagnostics_cfg.grad_group_every
                ),
                log_nonfinite=should_log_every(
                    diagnostics_step, diagnostics_cfg.check_nonfinite_every
                ),
            )
        engine.step()
        micro_step += 1

        if accumulation_boundary:
            global_step += 1
            window_denom = max(1, log_window_micro_batches)
            avg_loss = reduce_mean(log_window_loss_sum / window_denom, distributed)
            avg_unweighted_loss = reduce_mean(
                log_window_unweighted_loss_sum / window_denom, distributed
            )
            avg_weighted_loss = reduce_mean(
                log_window_weighted_loss_sum / window_denom, distributed
            )
            avg_timestep = reduce_mean(
                log_window_timestep_sum / window_denom, distributed
            )
            avg_sigma = reduce_mean(log_window_sigma_sum / window_denom, distributed)
            avg_timestep_weight = reduce_mean(
                log_window_weight_sum / window_denom, distributed
            )
            avg_timestep_index = reduce_mean(
                log_window_timestep_index_sum / window_denom, distributed
            )
            last_loss_value = float(avg_loss.item())
            avg_slot_losses = {
                slot: reduce_mean(slot_loss_sum / window_denom, distributed)
                for slot, slot_loss_sum in log_window_slot_sums.items()
            }

            if rank == 0 and global_step % log_every == 0:
                print(
                    f"[step {global_step:06d}] epoch={epoch} "
                    f"position={position} loss={last_loss_value:.6f} "
                    f"loss_unweighted={float(avg_unweighted_loss.item()):.6f} "
                    f"loss_weighted={float(avg_weighted_loss.item()):.6f} "
                    f"timestep={float(avg_timestep.item()):.3f} "
                    f"timestep_index_mean={float(avg_timestep_index.item()):.3f} "
                    f"sigma={float(avg_sigma.item()):.6f} "
                    f"weight={float(avg_timestep_weight.item()):.6f} "
                    f"sample={item['sample_id']}",
                    flush=True,
                )
                writer.add_scalar("train/loss", last_loss_value, global_step)
                writer.add_scalar(
                    "train/loss_unweighted",
                    float(avg_unweighted_loss.item()),
                    global_step,
                )
                writer.add_scalar(
                    "train/loss_weighted",
                    float(avg_weighted_loss.item()),
                    global_step,
                )
                writer.add_scalar(
                    "loss/all_valid",
                    float(avg_unweighted_loss.item()),
                    global_step,
                )
                writer.add_scalar(
                    "train/timestep", float(avg_timestep.item()), global_step
                )
                writer.add_scalar(
                    "train/timestep_index_mean",
                    float(avg_timestep_index.item()),
                    global_step,
                )
                writer.add_scalar("train/sigma", float(avg_sigma.item()), global_step)
                writer.add_scalar(
                    "train/timestep_weight",
                    float(avg_timestep_weight.item()),
                    global_step,
                )
                for slot, slot_loss in avg_slot_losses.items():
                    writer.add_scalar(
                        f"loss/slot_{slot}",
                        float(slot_loss.item()),
                        global_step,
                    )
                writer.add_scalar("train/epoch", epoch, global_step)
                for group in optimizer.param_groups:
                    writer.add_scalar(
                        f"train/lr/{group.get('name', 'group')}",
                        group["lr"],
                        global_step,
                    )

            if (
                bool(validation_cfg.get("enabled", False))
                and int(validation_cfg.get("every_steps", 150)) > 0
                and global_step % int(validation_cfg.get("every_steps", 150)) == 0
            ):
                run_validation(
                    pipe=pipe,
                    engine=engine,
                    val_samples=val_samples,
                    val_task_names=val_task_names,
                    cfg=cfg,
                    flow_cfg=flow_cfg,
                    distributed=distributed,
                    rank=rank,
                    world_size=world_size,
                    global_step=global_step,
                    writer=writer,
                )

            if global_step % save_every == 0 or global_step == max_steps:
                data_state = {
                    "global_step": global_step,
                    "micro_step": micro_step,
                    "epoch": epoch,
                    "position": position,
                    "next_global_item_index": micro_step * world_size,
                }
                client_state = {
                    **data_state,
                    "rng_state": capture_rng_state(),
                    "conditioning_mode": mode,
                    "flow_matching": flow_cfg.to_dict(),
                    "lr_scheduler": lr_cfg.to_dict(),
                    "training_module": "KeyframeWanTrainingModule/v1",
                }
                tag = f"step_{global_step:06d}"
                engine.save_checkpoint(
                    str(ds_ckpt_dir),
                    tag=tag,
                    client_state=client_state,
                )
                if rank == 0:
                    lightweight = ckpt_root / f"trainable_{tag}.pt"
                    save_lightweight_checkpoint(
                        engine.module.dit,
                        str(lightweight),
                        global_step,
                        last_loss_value,
                        cfg,
                        data_state,
                    )
                    print(f"[checkpoint] {tag}", flush=True)

            log_window_loss_sum.zero_()
            log_window_unweighted_loss_sum.zero_()
            log_window_weighted_loss_sum.zero_()
            log_window_timestep_sum.zero_()
            log_window_timestep_index_sum.zero_()
            log_window_sigma_sum.zero_()
            log_window_weight_sum.zero_()
            for slot_sum in log_window_slot_sums.values():
                slot_sum.zero_()
            log_window_micro_batches = 0

        del (
            item,
            target,
            fm_batch,
            pred,
            error,
            mask,
            loss,
            unweighted_loss,
            weighted_loss,
            per_slot_losses,
        )
        if (
            torch.cuda.is_available()
            and empty_cache_every > 0
            and micro_step % empty_cache_every == 0
        ):
            torch.cuda.empty_cache()

    if writer is not None:
        writer.close()
    barrier(distributed, local_rank)
    rank0_print(rank, f"[done] {out_dir}")
    if distributed and torch.distributed.is_initialized():
        torch.distributed.destroy_process_group()


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--config", required=True)
    parser.add_argument("--local_rank", type=int, default=0)
    parser.add_argument("--local-rank", type=int, default=0)
    args = parser.parse_args()
    train(load_json(args.config))


if __name__ == "__main__":
    main()
