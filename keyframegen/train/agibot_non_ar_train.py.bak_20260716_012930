                "sigma_shift": self.sigma_shift,
                "min_timestep_boundary": self.min_timestep_boundary,
                "max_timestep_boundary": self.max_timestep_boundary,
                "use_training_weight": self.use_training_weight,
                "allow_resume_mismatch": self.allow_resume_mismatch,
            }
        return {
            "mode": self.mode,
            "min_timestep": self.min_timestep,
            "max_timestep": self.max_timestep,
            "use_training_weight": self.use_training_weight,
            "allow_resume_mismatch": self.allow_resume_mismatch,
        }


@dataclass
class FlowMatchingBatch:
    timestep: torch.Tensor
    timestep_index: Optional[int]
    sigma: torch.Tensor
    noise: torch.Tensor
    noisy_latents: torch.Tensor
    training_target: torch.Tensor
    loss_mask: torch.Tensor
    training_weight: torch.Tensor


def parse_flow_matching_config(train_cfg: Dict[str, Any]) -> FlowMatchingConfig:
    raw = dict(train_cfg.get("flow_matching", {}))
    mode = str(raw.get("mode", "diffsynth_wan"))
    if mode not in SUPPORTED_FLOW_MATCHING_MODES:
        raise ValueError(
            f"Unsupported flow_matching.mode={mode!r}; supported="
            f"{sorted(SUPPORTED_FLOW_MATCHING_MODES)}"
        )
    allow_resume_mismatch = bool(raw.get("allow_resume_mismatch", False))
    if mode == "diffsynth_wan":
        cfg = FlowMatchingConfig(
            mode=mode,
            num_train_timesteps=int(raw.get("num_train_timesteps", 1000)),
            sigma_shift=float(raw.get("sigma_shift", 5.0)),
            min_timestep_boundary=float(raw.get("min_timestep_boundary", 0.0)),
            max_timestep_boundary=float(raw.get("max_timestep_boundary", 1.0)),
            use_training_weight=bool(raw.get("use_training_weight", True)),
            allow_resume_mismatch=allow_resume_mismatch,
        )
        if cfg.num_train_timesteps <= 1:
            raise ValueError("flow_matching.num_train_timesteps must be > 1")
        if cfg.sigma_shift <= 0:
            raise ValueError("flow_matching.sigma_shift must be > 0")
        if not (
            0.0 <= cfg.min_timestep_boundary
            < cfg.max_timestep_boundary
            <= 1.0
        ):
            raise ValueError(
                "flow_matching boundaries must satisfy "
                "0 <= min_timestep_boundary < max_timestep_boundary <= 1"
            )
        return cfg

    cfg = FlowMatchingConfig(
        mode=mode,
        min_timestep=float(raw.get("min_timestep", train_cfg.get("min_timestep", 0.0))),
        max_timestep=float(raw.get("max_timestep", train_cfg.get("max_timestep", 1000.0))),
        use_training_weight=bool(raw.get("use_training_weight", False)),
        allow_resume_mismatch=allow_resume_mismatch,
    )
    if cfg.max_timestep <= cfg.min_timestep:
        raise ValueError("uniform_linear requires max_timestep > min_timestep")
    if cfg.use_training_weight:
        raise ValueError(
            "flow_matching.use_training_weight=true is only supported for "
            "modes that initialize scheduler training weights"
        )
    return cfg


def scheduler_index_bounds(
    num_timesteps: int,
    min_boundary: float,
    max_boundary: float,
) -> Tuple[int, int]:
    min_index = int(min_boundary * num_timesteps)
    max_index = int(max_boundary * num_timesteps)
    min_index = max(0, min(num_timesteps - 1, min_index))
    max_index = max(min_index + 1, min(num_timesteps, max_index))
    return min_index, max_index


def validate_wan_training_scheduler(scheduler, flow_cfg: FlowMatchingConfig) -> None:
    if not hasattr(scheduler, "timesteps") or not hasattr(scheduler, "sigmas"):
        raise RuntimeError("Scheduler is missing timesteps/sigmas after initialization")
    if len(scheduler.timesteps) != flow_cfg.num_train_timesteps:
        raise RuntimeError(
            f"Scheduler timesteps length={len(scheduler.timesteps)}, "
            f"expected {flow_cfg.num_train_timesteps}"
        )
    if len(scheduler.sigmas) != flow_cfg.num_train_timesteps:
        raise RuntimeError(
            f"Scheduler sigmas length={len(scheduler.sigmas)}, "
            f"expected {flow_cfg.num_train_timesteps}"
        )
    if not torch.isfinite(scheduler.timesteps).all().item():
        raise RuntimeError("Scheduler timesteps contain NaN or Inf")
    if not torch.isfinite(scheduler.sigmas).all().item():
        raise RuntimeError("Scheduler sigmas contain NaN or Inf")
    if flow_cfg.use_training_weight and not hasattr(
        scheduler, "linear_timesteps_weights"
    ):
        raise RuntimeError(
            "flow_matching.use_training_weight=true but scheduler has no "
            "linear_timesteps_weights"
        )
    if flow_cfg.use_training_weight and len(scheduler.linear_timesteps_weights) != len(
        scheduler.timesteps
    ):
        raise RuntimeError("Scheduler training weights length mismatch")
    if flow_cfg.use_training_weight and not torch.isfinite(
        scheduler.linear_timesteps_weights
    ).all().item():
        raise RuntimeError("Scheduler training weights contain NaN or Inf")
    if not torch.allclose(
        scheduler.timesteps.detach().float(),
        scheduler.sigmas.detach().float() * 1000.0,
        atol=1e-3,
        rtol=1e-4,
    ):
        raise RuntimeError(
            "Wan scheduler invariant failed: timestep should be sigma * 1000"
        )


def initialize_flow_matching_scheduler(pipe, flow_cfg: FlowMatchingConfig) -> None:
    if flow_cfg.mode != "diffsynth_wan":
        return
    pipe.scheduler.set_timesteps(
        flow_cfg.num_train_timesteps,
        training=True,
        shift=flow_cfg.sigma_shift,
    )
    validate_wan_training_scheduler(pipe.scheduler, flow_cfg)


def fixed_validation_noise_and_timestep(
    shape: torch.Size,
    sample_index: int,
    seed: int,
    flow_cfg: FlowMatchingConfig,
    device,
    dtype: torch.dtype,
    scheduler=None,
) -> Tuple[torch.Tensor, Optional[int], Optional[torch.Tensor]]:
    generator = torch.Generator(device="cpu")
    generator.manual_seed(int(seed) + int(sample_index))
    noise_cpu = torch.randn(shape, generator=generator, dtype=torch.float32)
    noise = noise_cpu.to(device=device, dtype=dtype)
    if flow_cfg.mode == "diffsynth_wan":
        if scheduler is None:
            raise ValueError("scheduler is required for diffsynth_wan validation")
        min_index, max_index = scheduler_index_bounds(
            len(scheduler.timesteps),
            flow_cfg.min_timestep_boundary,
            flow_cfg.max_timestep_boundary,
        )
        timestep_index = int(
            torch.randint(min_index, max_index, (1,), generator=generator).item()
        )
        return noise, timestep_index, None
    timestep_cpu = torch.empty((shape[0],), dtype=torch.float32).uniform_(
        flow_cfg.min_timestep,
        flow_cfg.max_timestep,
        generator=generator,
    )
    return noise, None, timestep_cpu.to(device=device)


def build_flow_matching_batch(
    pipe,
    target_latents: torch.Tensor,
    first_frame_latents: Optional[torch.Tensor],
    fuse_vae_embedding_in_latents: bool,
    flow_cfg: FlowMatchingConfig,
    deterministic_noise: Optional[torch.Tensor] = None,
    deterministic_timestep_index: Optional[int] = None,
    deterministic_timestep: Optional[torch.Tensor] = None,
) -> FlowMatchingBatch:
    device = target_latents.device
    dtype = target_latents.dtype
    if flow_cfg.mode == "diffsynth_wan":
        scheduler = pipe.scheduler
        min_index, max_index = scheduler_index_bounds(
            len(scheduler.timesteps),
            flow_cfg.min_timestep_boundary,
            flow_cfg.max_timestep_boundary,
        )
        if deterministic_timestep_index is None:
            timestep_index = int(
                torch.randint(min_index, max_index, (1,), device=device).item()
            )
        else:
            timestep_index = int(deterministic_timestep_index)
            if timestep_index < min_index or timestep_index >= max_index:
                raise ValueError(
                    f"timestep_index={timestep_index} outside configured "
                    f"[{min_index}, {max_index})"
                )
        timestep = scheduler.timesteps[timestep_index].to(
            dtype=dtype,
            device=device,
        ).reshape(1)
        noise = (
            deterministic_noise.to(device=device, dtype=dtype)
            if deterministic_noise is not None
            else torch.randn_like(target_latents)
        )
        noisy = scheduler.add_noise(target_latents, noise, timestep)
        training_target = scheduler.training_target(target_latents, noise, timestep)
        sigma = scheduler.sigmas[timestep_index].to(device=device, dtype=dtype)
        if flow_cfg.use_training_weight:
            training_weight = scheduler.training_weight(timestep).to(
                device=device,
                dtype=torch.float32,
            )
        else:
            training_weight = torch.ones((), device=device, dtype=torch.float32)
    else:
        if deterministic_timestep is None:
            timestep = torch.empty(
                (target_latents.shape[0],), device=device, dtype=torch.float32
            ).uniform_(flow_cfg.min_timestep, flow_cfg.max_timestep)
        else:
            timestep = deterministic_timestep.to(device=device, dtype=torch.float32)
            if timestep.ndim == 0:
                timestep = timestep.reshape(1)
        noise = (
            deterministic_noise.to(device=device, dtype=dtype)
            if deterministic_noise is not None
            else torch.randn_like(target_latents)
        )
        sigma = (timestep / 1000.0).view(
            target_latents.shape[0], 1, 1, 1, 1
        ).to(target_latents)
        noisy = (1.0 - sigma) * target_latents + sigma * noise
        training_target = noise - target_latents
        timestep_index = None
        training_weight = torch.ones((), device=device, dtype=torch.float32)

    loss_mask = torch.ones_like(training_target)
    if fuse_vae_embedding_in_latents and first_frame_latents is not None:
        noisy[:, :, :1] = first_frame_latents
        loss_mask[:, :, :1] = 0

    return FlowMatchingBatch(
        timestep=timestep,
        timestep_index=timestep_index,
        sigma=sigma.reshape(()),
        noise=noise,
        noisy_latents=noisy,
        training_target=training_target,
        loss_mask=loss_mask,
        training_weight=training_weight.reshape(()),
    )


def sigma_bin(sigma: torch.Tensor, num_bins: int) -> int:
    if num_bins <= 1:
        return 0
    value = float(sigma.detach().float().mean().item())
    index = int(value * num_bins)
    return max(0, min(num_bins - 1, index))


def timestep_bin(
    timestep: torch.Tensor,
    min_t: float,
    max_t: float,
    num_bins: int,
) -> int:
    if num_bins <= 1 or max_t <= min_t:
        return 0
    value = float(timestep.detach().float().mean().item())
    index = int((value - min_t) / (max_t - min_t) * num_bins)
    return max(0, min(num_bins - 1, index))


def all_reduce_sum(value: torch.Tensor, distributed: bool) -> torch.Tensor:
    out = value.detach().clone()
    if distributed:
        torch.distributed.all_reduce(out, op=torch.distributed.ReduceOp.SUM)
    return out


