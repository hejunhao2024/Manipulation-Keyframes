def load_json(path: str) -> Dict[str, Any]:
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def ensure_dir(path: str) -> None:
    Path(path).mkdir(parents=True, exist_ok=True)


def read_manifest(path: str) -> List[str]:
    with open(path, "r", encoding="utf-8") as f:
        return [
            line.strip()
            for line in f
            if line.strip() and not line.lstrip().startswith("#")
        ]


def resolve_manifest_item(item: str, data_root: Optional[str] = None) -> str:
    path = Path(item)
    if path.is_absolute():
        return str(path)
    if data_root:
        return str(Path(data_root) / path)
    return str(path)


def read_sample_id(sample_dir: str) -> str:
    sample_path = Path(sample_dir)
    ann_path = sample_path / "annotation.json"
    if not ann_path.exists():
        return sample_path.name
    ann = load_json(str(ann_path))
    for key in ("id", "sample_id", "sample_short"):
        value = ann.get(key)
        if value:
            return str(value).strip("/")
    return sample_path.name


def init_distributed() -> Tuple[bool, int, int, int]:
    local_rank = int(os.environ.get("LOCAL_RANK", 0))
    if torch.cuda.is_available():
        torch.cuda.set_device(local_rank)

    distributed = "RANK" in os.environ and "WORLD_SIZE" in os.environ
    rank = int(os.environ.get("RANK", 0))
    world_size = int(os.environ.get("WORLD_SIZE", 1))

    if distributed and not torch.distributed.is_initialized():
        from datetime import timedelta
        torch.distributed.init_process_group(
            backend="nccl",
            timeout=timedelta(hours=2),
        )
    return distributed, rank, world_size, local_rank


def barrier(distributed: bool, local_rank: int) -> None:
    if not distributed:
        return
    if torch.cuda.is_available():
        torch.distributed.barrier(device_ids=[local_rank])
    else:
        torch.distributed.barrier()


def rank0_print(rank: int, *args, **kwargs) -> None:
    if rank == 0:
        print(*args, **kwargs, flush=True)


def seed_everything(seed: int, rank: int) -> None:
    seed = int(seed) + rank
    random.seed(seed)
    np.random.seed(seed % (2**32 - 1))
    torch.manual_seed(seed)
    if torch.cuda.is_available():
        torch.cuda.manual_seed_all(seed)


def capture_rng_state() -> Dict[str, Any]:
    state = {
        "python": random.getstate(),
        "numpy": np.random.get_state(),
        "torch": torch.get_rng_state(),
    }
    if torch.cuda.is_available():
        state["cuda"] = torch.cuda.get_rng_state_all()
    return state


def restore_rng_state(state: Optional[Dict[str, Any]]) -> None:
    if not state:
        return
    random.setstate(state["python"])
    np.random.set_state(state["numpy"])
    torch.set_rng_state(state["torch"])
    if torch.cuda.is_available() and "cuda" in state:
        torch.cuda.set_rng_state_all(state["cuda"])


def make_epoch_order(num_samples: int, epoch: int, seed: int, shuffle: bool) -> List[int]:
    order = list(range(num_samples))
    if shuffle:
        random.Random(seed + epoch).shuffle(order)
    return order


class LoRALinear(nn.Module):
    def __init__(self, base: nn.Linear, rank: int, alpha: int, dropout: float):
        super().__init__()
        self.base = base
        self.rank = int(rank)
        self.alpha = int(alpha)
        self.scale = self.alpha / self.rank
        for p in self.base.parameters():
            p.requires_grad_(False)

        self.dropout = nn.Dropout(dropout) if dropout > 0 else nn.Identity()
        self.lora_A = nn.Parameter(
            torch.empty(
                self.rank,
                base.in_features,
                dtype=base.weight.dtype,
                device=base.weight.device,
            )
        )
        self.lora_B = nn.Parameter(
            torch.zeros(
                base.out_features,
                self.rank,
                dtype=base.weight.dtype,
                device=base.weight.device,
            )
        )
        nn.init.kaiming_uniform_(self.lora_A, a=math.sqrt(5))

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        base_out = self.base(x)
        z = self.dropout(x).to(self.lora_A)
        z = z @ self.lora_A.t()
        z = z @ self.lora_B.t()
        return base_out + z.to(base_out) * self.scale


def get_parent_module(root: nn.Module, module_name: str):
    parts = module_name.split(".")
    parent = root
    for part in parts[:-1]:
        parent = getattr(parent, part)
    return parent, parts[-1]


def inject_lora(
    model: nn.Module,
    target_keywords: List[str],
    skip_keywords: List[str],
    rank: int,
    alpha: int,
    dropout: float,
) -> List[str]:
    replaced: List[str] = []
    for name, module in list(model.named_modules()):
        if not isinstance(module, nn.Linear):
            continue
        if not any(k in name for k in target_keywords):
            continue
        if any(k in name for k in skip_keywords):
            continue
        parent, child_name = get_parent_module(model, name)
        setattr(parent, child_name, LoRALinear(module, rank, alpha, dropout))
        replaced.append(name)
    return replaced


def parameter_count(items) -> int:
    total = 0
    for item in items:
        parameter = item[1] if isinstance(item, tuple) else item
        total += parameter.numel()
    return total


def print_parameter_group_report(
    groups: Dict[str, List[Tuple[str, nn.Parameter]]],
    lr_map: Dict[str, float],
    weight_decay: float,
    rank: int,
) -> None:
    if rank != 0:
        return
    for group_name, items in groups.items():
        names = [name for name, _ in items]
        rank0_print(
            rank,
            f"[param_group] {group_name} tensors={len(items)} "
            f"params={parameter_count(items) / 1e6:.3f}M "
            f"lr={lr_map[group_name]:.8g} weight_decay={weight_decay:.8g}",
        )
        preview = names[:10]
        tail = names[-10:] if len(names) > 10 else []
        for name in preview:
            rank0_print(rank, f"  [first] {name}")
        for name in tail:
            rank0_print(rank, f"  [last] {name}")


def print_absent_parameter_groups(
    groups: Dict[str, List[Tuple[str, nn.Parameter]]],
    rank: int,
) -> None:
    if rank != 0:
        return
    for group_name in PARAMETER_GROUP_NAMES:
        if not groups.get(group_name):
            rank0_print(rank, f"[param_group] {group_name} absent; grad metrics skipped")


def config_lr(train_cfg: Dict[str, Any], key: str, fallback_key: str) -> float:
    if key in train_cfg:
        return float(train_cfg[key])
    return float(train_cfg[fallback_key])


def configure_trainable(model: nn.Module, train_cfg: Dict[str, Any], rank: int):
    for p in model.parameters():
        p.requires_grad_(False)

    mode = train_cfg["train_mode"]
    full_keywords = list(train_cfg.get("full_train_keywords", []))
    lora_cfg = train_cfg.get("lora", {})
    lora_targets = list(lora_cfg.get("target_keywords", []))
    allow_lora_full_overlap = bool(
        train_cfg.get("allow_lora_and_full_overlap", False)
    )
    overlap = sorted(
        {
            f"{full_keyword}<->{lora_keyword}"
            for full_keyword in full_keywords
            for lora_keyword in lora_targets
            if full_keyword in lora_keyword or lora_keyword in full_keyword
        }
    )
    if overlap and not allow_lora_full_overlap:
        raise ValueError(
            "Refusing to LoRA and full fine-tune the same module keywords: "
            f"{overlap}. Set train.allow_lora_and_full_overlap=true only if "
            "this is intentional."
        )

    if mode == "lora_plus_full_keywords":
        replaced = inject_lora(
            model=model,
            target_keywords=lora_targets,
            skip_keywords=list(lora_cfg.get("skip_keywords", [])),
            rank=int(lora_cfg["rank"]),
            alpha=int(lora_cfg["alpha"]),
            dropout=float(lora_cfg["dropout"]),
        )
        rank0_print(rank, f"[LoRA] injected={len(replaced)}")
    elif mode == "full_keywords_only":
        replaced = []
    else:
        raise ValueError(f"Unsupported train_mode: {mode}")

    groups = {
        "self_attn_lora": [],
        "cross_attn_lora": [],
        "cross_attn_full": [],
        "full_extra": [],
    }
    named_trainable = []
    assigned_parameter_ids = {}

    for name, p in model.named_parameters():
        if any(k in name for k in full_keywords):
            p.requires_grad_(True)
        if "lora_A" in name or "lora_B" in name:
            p.requires_grad_(True)

        if not p.requires_grad:
            continue
        named_trainable.append((name, p.numel()))
        if ("lora_A" in name or "lora_B" in name) and "self_attn" in name:
            group_name = "self_attn_lora"
        elif ("lora_A" in name or "lora_B" in name) and "cross_attn" in name:
            group_name = "cross_attn_lora"
        elif "lora_A" in name or "lora_B" in name:
            group_name = "full_extra"
        elif "cross_attn" in name:
            group_name = "cross_attn_full"
        else:
            group_name = "full_extra"

        parameter_id = id(p)
        if parameter_id in assigned_parameter_ids:
            raise RuntimeError(
                f"Parameter {name} assigned to both "
                f"{assigned_parameter_ids[parameter_id]} and {group_name}"
            )
        assigned_parameter_ids[parameter_id] = group_name
        groups[group_name].append((name, p))

    if not named_trainable:
        raise RuntimeError("No trainable parameters selected.")

    trainable_ids = {id(p) for _, p in model.named_parameters() if p.requires_grad}
    grouped_ids = {id(p) for items in groups.values() for _, p in items}
    if trainable_ids != grouped_ids:
        missing = trainable_ids - grouped_ids
        extra = grouped_ids - trainable_ids
        raise RuntimeError(
            f"Trainable/grouped parameter mismatch: missing={len(missing)} "
            f"extra={len(extra)}"
        )

    if "cross_attn" in lora_targets and not groups["cross_attn_lora"]:
        raise RuntimeError(
            "Config requests cross-attn LoRA, but cross_attn_lora group is empty."
        )

    lr_map = {
        "self_attn_lora": config_lr(train_cfg, "self_attn_lora_lr", "lora_lr"),
        "cross_attn_lora": config_lr(
            train_cfg, "cross_attn_lora_lr", "cross_attn_lr"
        ),
        "cross_attn_full": config_lr(
            train_cfg, "cross_attn_full_lr", "cross_attn_lr"
        ),
        "full_extra": float(train_cfg["full_extra_lr"]),
    }
    print_parameter_group_report(
        groups,
        lr_map,
        weight_decay=float(train_cfg["weight_decay"]),
        rank=rank,
    )

    rank0_print(
        rank,
        "[trainable] total="
        f"{sum(n for _, n in named_trainable) / 1e6:.3f}M "
        f"tensors={len(named_trainable)}",
    )
    return groups, named_trainable


def build_optimizer(
    groups: Dict[str, List[Tuple[str, nn.Parameter]]],
    train_cfg: Dict[str, Any],
    named_trainable: List[Tuple[str, int]],
):
    optim_groups = []
    lr_map = {
        "self_attn_lora": config_lr(train_cfg, "self_attn_lora_lr", "lora_lr"),
        "cross_attn_lora": config_lr(
            train_cfg, "cross_attn_lora_lr", "cross_attn_lr"
        ),
        "cross_attn_full": config_lr(
            train_cfg, "cross_attn_full_lr", "cross_attn_lr"
        ),
        "full_extra": float(train_cfg["full_extra_lr"]),
    }
    for name in PARAMETER_GROUP_NAMES:
        if groups[name]:
            optim_groups.append(
                {
                    "params": [parameter for _, parameter in groups[name]],
                    "lr": lr_map[name],
                    "name": name,
                }
            )

    optimizer = torch.optim.AdamW(
        optim_groups,
        weight_decay=float(train_cfg["weight_decay"]),
        betas=tuple(train_cfg["betas"]),
        eps=float(train_cfg["eps"]),
        foreach=False,
        fused=False,
    )
    parameters = [p for group in optim_groups for p in group["params"]]
    optimizer_parameter_count = sum(p.numel() for p in parameters)
    trainable_parameter_count = sum(n for _, n in named_trainable)
    if optimizer_parameter_count != trainable_parameter_count:
        raise RuntimeError(
            f"Optimizer has {optimizer_parameter_count} parameters, but "
            f"trainable set has {trainable_parameter_count}."
        )
    return optimizer, parameters


@dataclass(frozen=True)
class LRSchedulerConfig:
    type: str = "constant"
    warmup_steps: int = 0

    def to_dict(self) -> Dict[str, Any]:
        return {"type": self.type, "warmup_steps": self.warmup_steps}


def parse_lr_scheduler_config(train_cfg: Dict[str, Any]) -> LRSchedulerConfig:
    raw = dict(train_cfg.get("lr_scheduler", {}))
    scheduler_type = str(raw.get("type", "constant"))
    warmup_steps = int(raw.get("warmup_steps", 0))
    if warmup_steps < 0:
        raise ValueError("train.lr_scheduler.warmup_steps must be >= 0")
    if scheduler_type == "constant_with_warmup" and warmup_steps <= 0:
        raise ValueError(
            "train.lr_scheduler.type=constant_with_warmup requires warmup_steps > 0"
        )
    if scheduler_type == "constant" and warmup_steps != 0:
        raise ValueError("train.lr_scheduler.type=constant requires warmup_steps=0")
    if scheduler_type not in {"constant", "constant_with_warmup"}:
        raise ValueError(f"Unsupported train.lr_scheduler.type: {scheduler_type}")
    return LRSchedulerConfig(type=scheduler_type, warmup_steps=warmup_steps)


def lr_lambda_for_step(step: int, lr_cfg: LRSchedulerConfig) -> float:
    if lr_cfg.type == "constant":
        return 1.0
    return min(1.0, max(1, int(step)) / float(lr_cfg.warmup_steps))


def build_lr_scheduler(optimizer, lr_cfg: LRSchedulerConfig):
    return LambdaLR(optimizer, lr_lambda=lambda step: lr_lambda_for_step(step, lr_cfg))


def import_pipeline(conditioning_mode: str):
    if conditioning_mode == "local_only":
        from diffsynth.pipelines.keyframe_local_context import WanVideoPipeline
        return WanVideoPipeline
    if conditioning_mode == "dual_context":
        from diffsynth.pipelines.keyframe_dual_context import WanVideoPipeline
        return WanVideoPipeline
    raise ValueError(
        f"conditioning_mode must be local_only or dual_context, got {conditioning_mode}"
    )


def build_pipe(cfg: Dict[str, Any], conditioning_mode: str, local_rank: int):
    WanVideoPipeline = import_pipeline(conditioning_mode)
    model_cfg = cfg["model"]
    train_cfg = cfg["train"]
    model_id = model_cfg["model_id"]
    model_path = model_cfg.get("model_path")
    dtype = torch.bfloat16
    device = f"cuda:{local_rank}" if torch.cuda.is_available() else "cpu"

    vram_config = {
        "offload_dtype": dtype,
        "offload_device": model_cfg["offload_device"],
        "onload_dtype": dtype,
        "onload_device": model_cfg["onload_device"],
        "computation_dtype": dtype,
        "computation_device": device,
    }

    pipe = WanVideoPipeline.from_pretrained(
        torch_dtype=dtype,
        device=device,
        model_configs=[
            (
                ModelConfig(
                    path=sorted(
                        str(p)
                        for p in Path(model_path).glob(
                            "diffusion_pytorch_model*.safetensors"
                        )
                    ),
                    **vram_config,
                )
                if model_path
                else ModelConfig(
                    model_id=model_id,
                    origin_file_pattern="diffusion_pytorch_model*.safetensors",
                    **vram_config,
                )
            ),
        ],
        tokenizer_config=None,
        redirect_common_files=False,
        vram_limit=model_cfg.get("vram_limit_gb"),
        **(
            {
                "dual_context_global_scale_init": float(
                    train_cfg.get("dual_context", {}).get("global_scale_init", 1.0)
                ),
                "dual_context_local_scale_init": float(
                    train_cfg.get("dual_context", {}).get("local_scale_init", 1.0)
                ),
                "dual_context_max_context_scale": float(
                    train_cfg.get("dual_context", {}).get("max_context_scale", 2.0)
                ),
            }
            if conditioning_mode == "dual_context"
            else {}
        ),
    )
    return pipe


class KeyframeWanTrainingModule(nn.Module):
    def __init__(self, pipe):
        super().__init__()
        self.dit = pipe.dit
        object.__setattr__(self, "_pipe", pipe)

    def forward(self, **model_kwargs):
        return self._pipe.model_fn(dit=self.dit, **model_kwargs)


def trainable_parameter_ids(model: nn.Module) -> Dict[str, int]:
    return {name: id(p) for name, p in model.named_parameters() if p.requires_grad}


def assert_training_module_ownership(
    training_module: KeyframeWanTrainingModule,
    engine,
    expected_trainable_ids: Dict[str, int],
    rank: int,
    local_rank: int,
    enforce_cuda_device: bool = True,
) -> None:
    if engine.module.dit is not training_module.dit:
        raise RuntimeError("DeepSpeed wrapper does not own the expected DiT object")
    module_ids = trainable_parameter_ids(engine.module.dit)
    if module_ids != expected_trainable_ids:
        changed = sorted(
            name
            for name, parameter_id in expected_trainable_ids.items()
            if module_ids.get(name) != parameter_id
        )
        raise RuntimeError(
            "Trainable parameter identity changed after DeepSpeed initialization: "
            + ", ".join(changed[:20])
        )
    wrapper_trainable_ids = {
        id(p) for _, p in engine.module.named_parameters() if p.requires_grad
    }
    missing = set(expected_trainable_ids.values()) - wrapper_trainable_ids
    if missing:
        raise RuntimeError(
            f"{len(missing)} trainable DiT parameters are not owned by the wrapper"
        )
    if enforce_cuda_device and torch.cuda.is_available():
        expected_device = torch.device(f"cuda:{local_rank}")
        bad_devices = [
            (name, str(p.device))
            for name, p in engine.module.dit.named_parameters()
            if p.requires_grad and p.device != expected_device
        ]
        if bad_devices:
            raise RuntimeError(
                "Trainable parameters are on unexpected devices after DeepSpeed "
                f"initialization: {bad_devices[:10]}"
            )
    if enforce_cuda_device:
        cpu_params = [
            name
            for name, p in engine.module.dit.named_parameters()
            if p.requires_grad and p.device.type == "cpu"
        ]
        if cpu_params:
            raise RuntimeError(
                "Trainable parameters moved back to CPU after DeepSpeed initialization: "
                + ", ".join(cpu_params[:20])
            )
    rank0_print(rank, "[runtime] DeepSpeed wrapper owns DiT forward and trainable params")


def as_5d(x: torch.Tensor, name: str) -> torch.Tensor:
    if x.ndim == 4:
        return x.unsqueeze(0)
    if x.ndim == 5:
        return x
    raise ValueError(f"{name} must be 4D/5D, got {tuple(x.shape)}")


def as_local_context(x: torch.Tensor) -> torch.Tensor:
    if x.ndim == 3:
        return x.unsqueeze(0)
    if x.ndim == 4:
        return x
    if x.ndim == 5 and x.shape[1] == 1:
        return x[:, 0]
    raise ValueError(f"local context must be 3D/4D, got {tuple(x.shape)}")


def as_global_context(x: torch.Tensor) -> torch.Tensor:
    if x.ndim == 2:
        return x.unsqueeze(0)
    if x.ndim == 3:
        return x
    raise ValueError(f"global context must be 2D/3D, got {tuple(x.shape)}")


def move(x, device, dtype=torch.bfloat16):
    if x is None:
        return None
    return x.to(device=device, dtype=dtype, non_blocking=True)


def same_path(left: str, right: str) -> bool:
    return os.path.realpath(left) == os.path.realpath(right)


def require_cache_sample_path(
    obj: Dict[str, Any],
    key: str,
    sample_dir: str,
    sample_id: str,
    cache_path: Path,
) -> None:
    cached = obj.get(key)
    if cached is None:
        return
    if not same_path(str(cached), sample_dir):
        raise ValueError(
            f"{sample_id}: {cache_path} records {key}={cached!r}, "
            f"but manifest sample_dir={sample_dir!r}"
        )


def validate_finite_tensor(name: str, value: Optional[torch.Tensor], sample_id: str):
    if value is None:
        return
    if not torch.isfinite(value).all().item():
        raise ValueError(f"{sample_id}: tensor {name} contains NaN or Inf")


def tensor_summary(name: str, value: Optional[torch.Tensor]) -> str:
    if value is None:
        return f"{name}: None"
    stats = value.detach().float()
    return (
        f"{name}: shape={tuple(value.shape)} dtype={value.dtype} "
        f"device={value.device} min={stats.min().item():.6g} "
        f"max={stats.max().item():.6g} mean={stats.mean().item():.6g} "
        f"std={stats.std(unbiased=False).item():.6g}"
    )


def print_first_batch_summary(rank: int, item: Dict[str, Any]) -> None:
    if rank != 0:
        return
    rank0_print(rank, f"[first_batch] sample_id={item['sample_id']}")
    for name in (
        "target_latents",
        "first_frame_latents",
        "y",
        "clip_feature",
    ):
        rank0_print(rank, "[first_batch] " + tensor_summary(name, item.get(name)))
    for name, value in item["conditions"].items():
        rank0_print(rank, "[first_batch] " + tensor_summary(name, value))


def load_cached_item(
    sample_dir: str,
    data_cfg: Dict[str, Any],
    conditioning_mode: str,
    device,
    expected_slots: int,
) -> Dict[str, Any]:
    sample_id = read_sample_id(sample_dir)
    text_path = Path(data_cfg["text_cache_dir"]) / f"{sample_id}.pt"
    vae_path = Path(data_cfg["vae_cache_dir"]) / f"{sample_id}.pt"

    if not text_path.exists():
        raise FileNotFoundError(text_path)
    if not vae_path.exists():
        raise FileNotFoundError(vae_path)

    text_obj = torch.load(text_path, map_location="cpu", weights_only=False)
    vae_obj = torch.load(vae_path, map_location="cpu", weights_only=False)

    require_cache_sample_path(text_obj, "sample_dir", sample_dir, sample_id, text_path)
    require_cache_sample_path(vae_obj, "sample_dir", sample_dir, sample_id, vae_path)

    text_slots = int(text_obj.get("num_slots", 0))
    vae_slots = int(vae_obj.get("num_slots", 0))
    text_frames = int(text_obj.get("num_frames", 0))
    vae_frames = int(vae_obj.get("num_frames", 0))
    if text_slots != vae_slots:
        raise ValueError(
            f"{sample_id}: text num_slots={text_slots}, vae num_slots={vae_slots}"
        )
    if text_frames != vae_frames:
        raise ValueError(
            f"{sample_id}: text num_frames={text_frames}, vae num_frames={vae_frames}"
        )
    if vae_slots != expected_slots:
        raise ValueError(
            f"{sample_id}: expected {expected_slots} slots, cache has {vae_slots}"
        )
    expected_frames = 1 + (expected_slots - 1) * 4
    if vae_frames != expected_frames:
        raise ValueError(
            f"{sample_id}: expected num_frames={expected_frames}, got {vae_frames}"
        )

    target_latents = move(
        as_5d(vae_obj["target_latents"], "target_latents"), device
    )
    y = move(as_5d(vae_obj["y"], "y"), device)
    first_frame_latents = vae_obj.get("first_frame_latents")
    if first_frame_latents is not None:
        first_frame_latents = move(
            as_5d(first_frame_latents, "first_frame_latents"), device
        )
    clip_feature = move(text_obj.get("clip_feature"), device)

    if conditioning_mode == "local_only":
        context = move(as_local_context(text_obj["context"]), device)
        conditions = {"context": context}
    else:
        global_context = move(
            as_global_context(text_obj["global_context"]), device
        )
        local_context = move(
            as_local_context(text_obj["local_context"]), device
        )
        conditions = {
            "global_context": global_context,
            "local_context": local_context,
        }

    if target_latents.shape[2] != expected_slots:
        raise ValueError(
            f"{sample_id}: target_latents F={target_latents.shape[2]}, "
            f"expected {expected_slots}"
        )
    local_context = conditions.get("context")
    if local_context is None:
        local_context = conditions.get("local_context")
    if local_context is not None and local_context.shape[1] != expected_slots:
        raise ValueError(
            f"{sample_id}: context slots={local_context.shape[1]}, "
            f"expected {expected_slots}"
        )
    if local_context is not None and target_latents.shape[0] != local_context.shape[0]:
        raise ValueError(
            f"{sample_id}: target batch={target_latents.shape[0]}, "
            f"context batch={local_context.shape[0]}"
        )
    if first_frame_latents is not None and first_frame_latents.shape[2] != 1:
        raise ValueError(
            f"{sample_id}: first_frame_latents F="
            f"{first_frame_latents.shape[2]}, expected 1"
        )

    validate_finite_tensor("target_latents", target_latents, sample_id)
    validate_finite_tensor("first_frame_latents", first_frame_latents, sample_id)
    validate_finite_tensor("y", y, sample_id)
    validate_finite_tensor("clip_feature", clip_feature, sample_id)
    for key, value in conditions.items():
        validate_finite_tensor(key, value, sample_id)

    return {
        "sample_id": sample_id,
        "conditions": conditions,
        "clip_feature": clip_feature,
        "target_latents": target_latents,
        "y": y,
        "first_frame_latents": first_frame_latents,
        "fuse_vae_embedding_in_latents": bool(
            vae_obj.get("fuse_vae_embedding_in_latents", False)
        ),
        "text_path": str(text_path),
        "vae_path": str(vae_path),
    }


def collect_trainable_state(model: nn.Module) -> Dict[str, torch.Tensor]:
    return {
        name: p.detach().cpu()
        for name, p in model.named_parameters()
        if p.requires_grad
    }


def load_trainable_weights(model: nn.Module, path: str, rank: int) -> int:
    obj = torch.load(path, map_location="cpu", weights_only=False)
    state = obj.get("trainable_state_dict", obj)
    current = model.state_dict()
    compatible = {
        k: v.to(dtype=current[k].dtype)
        for k, v in state.items()
        if k in current and current[k].shape == v.shape
    }
    expected = [name for name, p in model.named_parameters() if p.requires_grad]
    if expected and not compatible:
        raise RuntimeError(
            f"No compatible trainable tensors loaded from {path}. "
            "Refusing to continue with an effectively empty weights resume."
        )
    model.load_state_dict(compatible, strict=False)
    rank0_print(rank, f"[resume weights] loaded={len(compatible)} from {path}")
    return int(obj.get("global_step", obj.get("step", 0)))


def save_lightweight_checkpoint(
    model: nn.Module,
    path: str,
    global_step: int,
    loss: float,
    cfg: Dict[str, Any],
    data_state: Dict[str, Any],
) -> None:
    ensure_dir(str(Path(path).parent))
    tmp = path + ".tmp"
    torch.save(
        {
            "global_step": global_step,
            "loss": float(loss),
            "trainable_state_dict": collect_trainable_state(model),
            "data_state": data_state,
            "config": cfg,
            "flow_matching": cfg.get("train", {}).get("flow_matching"),
        },
        tmp,
    )
    os.replace(tmp, path)


def reduce_mean(x: torch.Tensor, distributed: bool) -> torch.Tensor:
    out = x.detach().clone()
    if distributed:
        torch.distributed.all_reduce(out, op=torch.distributed.ReduceOp.SUM)
        out /= torch.distributed.get_world_size()
    return out


def masked_mse_loss(error: torch.Tensor, mask: torch.Tensor) -> torch.Tensor:
    return (error * mask).sum() / mask.sum().clamp_min(1.0)


def slot_mse_losses(error: torch.Tensor, mask: torch.Tensor) -> Dict[int, torch.Tensor]:
    losses = {}
    for slot in range(1, error.shape[2]):
        slot_error = error[:, :, slot]
        slot_mask = mask[:, :, slot]
        losses[slot] = masked_mse_loss(slot_error, slot_mask)
    return losses


def loss_parts(error: torch.Tensor, mask: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor]:
    return (error * mask).sum(), mask.sum()


@dataclass(frozen=True)
